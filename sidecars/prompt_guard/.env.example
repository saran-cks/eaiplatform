# Prompt Guard sidecar — local dev env. Copy to `.env` (gitignored) and fill HF_TOKEN.

# GATED MODEL: needed ONLY for the first download of Llama Prompt Guard 2.
# Get it at huggingface.co -> Settings -> Access Tokens (Read scope), AND accept the
# license at huggingface.co/meta-llama/Llama-Prompt-Guard-2-86M (same account).
# transformers/huggingface_hub read this from the environment automatically.
HF_TOKEN=

# --- service config (all optional; defaults shown) ---
GUARD_PORT=8001
GUARD_THRESHOLD=0.5            # block if P(malicious) >= this
GUARD_MAX_SEQ_LEN=512
GUARD_INTRA_OP_THREADS=4
GUARD_MAX_CONCURRENCY=8
# GUARD_MODEL_NAME=meta-llama/Llama-Prompt-Guard-2-86M
