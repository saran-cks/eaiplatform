# --- API base ---
# Empty = same-origin (use the Vite dev proxy below). Set to an absolute origin
# (e.g. https://api.example.com) when the SPA is served from a different host.
VITE_API_BASE_URL=

# Where the Vite dev server proxies the Core API surface to (dev only).
VITE_DEV_API_PROXY_TARGET=http://localhost:8000

# --- Auth provider selection ---
# "dev-mint" (HS256 token minted in-browser for local dev) | "cognito" (SRP against
# the user pool from our own login form — no Hosted UI redirect).
VITE_AUTH_PROVIDER=dev-mint

# --- Dev-mint (local only) ---
# MUST match the Core API's JWT_* settings (config/settings.py defaults shown).
# The shared HS256 secret is only safe for local dev; prod uses Cognito/RS256.
VITE_DEV_JWT_SECRET=change-me-dev-only
VITE_DEV_JWT_ISSUER=core-api
VITE_DEV_JWT_AUDIENCE=core-api-clients

# --- Cognito SRP (prod path; AUTH_PROVIDER=cognito) ---
# Public app client (no secret). Region is parsed from the pool id. VITE_COGNITO_TOKEN_USE
# MUST match the Core API's COGNITO_TOKEN_USE ("access" default; "id" carries
# custom:tenant_id without a pre-token Lambda). Fill these once the pool exists.
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_TOKEN_USE=access

# --- Observability ---
# Phoenix UI origin the observability tab links out to (shown only to obs:admin).
VITE_PHOENIX_URL=http://localhost:6006

# --- Agent mock seam (dev only) ---
# "1" (default) = in-browser mock agent stream + mock artifacts, so the agent
# surface (ActionStream, ArtifactViewer) is demoable without the live LangGraph
# backend. Set to "0" to hit the real /agent endpoints.
VITE_MOCK_AGENT=1
