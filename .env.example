# ----------------------------------------------------------------------------
# Core API — environment template. Copy to .env and fill real values.
# All variables are read by src/config/settings.py (pydantic-settings v2).
# ----------------------------------------------------------------------------

# --- Application ---
APP_NAME=core-api
APP_ENV=local                     # local | staging | prod
DEBUG=true
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_TO_FILE=false                 # false = stdout (CloudWatch). true = LOG_DIR files.
LOG_DIR=./logs
LOG_FILE=core-api.log

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- JWT (HS256 shared secret for local dev; swap to RS256/JWKS later) ---
JWT_SECRET=change-me-dev-only-not-for-prod
JWT_ALGORITHM=HS256
JWT_ISSUER=core-api
JWT_AUDIENCE=core-api-clients
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

# --- Postgres (local container; prod = RDS) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=core
POSTGRES_USER=core
POSTGRES_PASSWORD=core
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# --- Valkey (local container; prod = ElastiCache) ---
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_DB=0
VALKEY_PASSWORD=

# --- Qdrant (vector store; retrieval only — ingestion is a separate worker) ---
QDRANT_HOST=qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_USE_GRPC=true
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge

# --- Model server sidecar (bge-m3 embeddings; gRPC). Prod: 127.0.0.1 ---
MODEL_SERVER_HOST=model_server
MODEL_SERVER_PORT=50051
EMBED_MODEL=bge-m3
EMBED_DIM=1024
EMBED_SPARSE_ENABLED=true

# --- Prompt Guard sidecar (HTTP). Prod: 127.0.0.1 ---
GUARD_ENABLED=true
GUARD_GATEWAY_URL=http://guard_gateway:8001

# --- MCP external connectors (read-only phase 1; writes FUTURE) ---
MCP_ENABLED=true
MCP_MOCK_MODE=true
RISK_STORE_ENABLED=true            # persist DD-11 session risk to Valkey (cross-worker)
RISK_STORE_TTL_SECONDS=1800

# --- AWS Bedrock (Claude — SSE streaming) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6
BEDROCK_FAST_MODEL_ID=anthropic.claude-haiku-4-5-20251001
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.2

# --- Phoenix / OpenTelemetry ---
OTEL_ENABLED=true
OTEL_SERVICE_NAME=core-api               # also the Phoenix project name (OTLP service.name)
OTEL_EXPORTER_OTLP_ENDPOINT=http://phoenix:4317
PHOENIX_HTTP_ENDPOINT=http://phoenix:6006
PHOENIX_API_KEY=                         # blank for unauthenticated self-hosted Phoenix
OTEL_AUTOINSTRUMENT=false                # opt-in Bedrock+LangChain auto-instrumentation (extra: autoinstrument)
EVAL_ENABLED=false                       # online LLM-judge evals (faithfulness/QA/relevance/toxicity)
EVAL_SAMPLE_RATE=0.0                     # 0.0..1.0 fraction of chat turns to evaluate

# --- Cache TTLs (seconds) ---
CACHE_RESPONSE_TTL=3600           # response:{hash}
CACHE_CHUNK_TTL=86400             # chunk:{chunk_id}
SESSION_TTL=7200                  # session:{session_id} (sliding)

# --- Retrieval ---
RETRIEVAL_TOP_K=5
RRF_K=60
RERANK_ENABLED=false              # phase 1: hybrid+RRF only. Flip to enable reranker.
RERANK_SCORE_SPREAD_THRESHOLD=0.15

# --- Agent lifecycle ---
AGENT_SESSION_TTL_SECONDS=1800
AGENT_MAX_ITERATIONS=12

# --- A2A interop ---
A2A_ENABLED=true
A2A_REGISTRY_URL=

# --- Queue (ARQ on Valkey) ---
QUEUE_NAME=ingestion

# --- Daemon intervals (seconds) ---
REAPER_INTERVAL=60
WATCHDOG_INTERVAL=30
CLEANUP_INTERVAL=120
